{
  "name": "TestInput",
  "type": "object",
  "properties": {
    "prompt_id": {
      "type": "string",
      "description": "FK to Prompt"
    },
    "name": {
      "type": "string",
      "description": "A short label for this test case"
    },
    "system_prompt": {
      "type": "string",
      "description": "URL to the uploaded system prompt text file"
    },
    "reference_docs": {
      "type": "array",
      "description": "List of reference documents attached to this test input",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "prompt_id",
    "name"
  ]
}